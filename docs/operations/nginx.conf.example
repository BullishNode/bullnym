# Example Bullnym reverse-proxy fragments. Merge these into the existing TLS
# server after inspecting `nginx -T`; this is not a complete virtual host.

limit_req_zone $binary_remote_addr zone=bullnym_html:10m rate=10r/s;
limit_req_zone $binary_remote_addr zone=bullnym_api:10m rate=5r/s;
limit_req_zone $binary_remote_addr zone=bullnym_static:10m rate=30r/s;

server {
    # Trust only the actual edge proxy. It must overwrite client-supplied XFF.
    set_real_ip_from 100.64.0.2;
    real_ip_header X-Forwarded-For;

    # Must match donation.image_root_path. Generated social-card filenames are
    # immutable and content-addressed; serve them directly rather than proxying
    # via Rust.
    # In a multi-host deployment, use shared storage or ensure every serving
    # host runs the OG verification/reconciliation worker against its local root.
    location ^~ /img/og/ {
        alias /opt/payservice/data/images/og/;
        limit_req zone=bullnym_static burst=60 nodelay;
        types {
            image/jpeg jpg jpeg;
        }
        default_type application/octet-stream;
        add_header Cache-Control "public, max-age=31536000, immutable" always;
        add_header X-Content-Type-Options nosniff always;
        limit_except GET HEAD { deny all; }
        access_log off;
    }

    location ^~ /pwa-assets/ {
        limit_req zone=bullnym_static burst=60 nodelay;
        proxy_pass http://127.0.0.1:8080;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Permanent branded OG fallbacks are embedded in the Bullnym binary. Keep
    # this separate from /img/og/, which is host-local generated-image storage.
    location ^~ /og/ {
        limit_req zone=bullnym_static burst=60 nodelay;
        proxy_pass http://127.0.0.1:8080;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location = /sw.js {
        limit_req zone=bullnym_static burst=60 nodelay;
        proxy_pass http://127.0.0.1:8080;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # LUD-12 carries the payer's private comment in this GET query. Standard
    # nginx access formats include the complete request URI, so this endpoint
    # must not enter access logs. nginx error records can also include the full
    # request line, so discard location-local proxy errors and use Bullnym's
    # privacy-safe structured errors for diagnosis. Its trace span is redacted.
    location ^~ /lnurlp/callback/ {
        access_log off;
        error_log /dev/null crit;
        proxy_pass http://127.0.0.1:8080;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # The largest valid encrypted backup is 2 MiB before base64, so its JSON
    # envelope needs Bullnym's exact 3 MiB route ceiling instead of nginx's
    # default 1 MiB ceiling. Keep route use out of the access log; Bullnym emits
    # privacy-safe aggregate action/stream/size telemetry without keys or IPs.
    location = /api/v1/wallet-backups {
        access_log off;
        client_max_body_size 3m;
        limit_req zone=bullnym_api burst=10 nodelay;
        proxy_pass http://127.0.0.1:8080;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location = /api/v1/wallet-backups/fetch {
        access_log off;
        client_max_body_size 8k;
        limit_req zone=bullnym_api burst=10 nodelay;
        proxy_pass http://127.0.0.1:8080;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location ~ ^/[a-z0-9-]+/manifest\.webmanifest$ {
        limit_req zone=bullnym_api burst=10 nodelay;
        proxy_pass http://127.0.0.1:8080;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location ~ ^/(?!\.well-known/|register|webhook/|health|ready|version|certification/|api/|img/|og/|pwa-assets/|sw\.js$|donation-page|lnurlp/) {
        limit_req zone=bullnym_html burst=100 nodelay;
        proxy_pass http://127.0.0.1:8080;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location / {
        proxy_pass http://127.0.0.1:8080;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}

# Validate with `nginx -t`, then verify /health, /ready, /version, /sw.js,
# /pwa-assets/, /og/fallback-live-v1.jpg, a generated social card, a
# manifest route, a Payment Page, a POS route, and backup fetch/store at the
# documented body boundaries. The /img/og location is read-only application
# output.
